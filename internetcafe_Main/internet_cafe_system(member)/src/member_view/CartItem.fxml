<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER_LEFT" prefHeight="118.0" spacing="14.0" styleClass="cart-item-premium" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="member_controllers.CartItemController">
    <padding>
        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
    </padding>

    <StackPane prefHeight="88.0" prefWidth="88.0" styleClass="cart-item-thumb-wrap-premium">
        <ImageView fx:id="imageView" fitHeight="62.0" fitWidth="62.0" pickOnBounds="true" preserveRatio="true" />
    </StackPane>

    <VBox spacing="7.0" HBox.hgrow="ALWAYS">
        <HBox alignment="TOP_LEFT" spacing="8.0">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label fx:id="nameLabel" styleClass="cart-item-title" text="Coca Cola" />
            </VBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label fx:id="priceLabel" styleClass="cart-item-price" text="P4.00" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="8.0" styleClass="cart-qty-box cart-qty-box-premium">
                <Button fx:id="decreaseQty" mnemonicParsing="false" onAction="#decreaseQty" prefHeight="28.0" prefWidth="28.0" text="−">
               <styleClass>
                  <String fx:value="cart-qty-button" />
                  <String fx:value="cart-qty-button-plus" />
               </styleClass></Button>
                <Label fx:id="qtyLabel" styleClass="cart-qty-label" text="1" />
                <Button fx:id="increaseQty" mnemonicParsing="false" onAction="#increaseQty" prefHeight="28.0" prefWidth="28.0" text="+">
               <styleClass>
                  <String fx:value="cart-qty-button" />
                  <String fx:value="cart-qty-button-plus" />
               </styleClass></Button>
            </HBox>
        </HBox>
          <Label fx:id="subtotalLabel" styleClass="cart-item-meta-label" text="Item SubTotal : " />
    </VBox>
</HBox>
