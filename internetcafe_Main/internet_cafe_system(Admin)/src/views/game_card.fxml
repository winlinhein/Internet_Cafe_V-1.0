<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="cardShell"
           maxWidth="332.0"
           minWidth="260.0"
           prefWidth="284.0"
           alignment="CENTER"
           styleClass="card-hover-shell"
           stylesheets="@../css/pixel_admin_reactive.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="admin_controllers.GameCardController">

    <padding>
        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
    </padding>

    <children>
        <VBox fx:id="cardRoot"
              alignment="TOP_CENTER"
              fillWidth="true"
              maxWidth="308.0"
              minWidth="248.0"
              prefWidth="284.0"
              spacing="12.0"
              stylesheets="@../css/pixel_admin_reactive.css">
            <styleClass>
                <String fx:value="game-card" />
                <String fx:value="customer-card" />
            </styleClass>

            <padding>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </padding>

            <children>
                <StackPane fx:id="imageWrap"
                           alignment="CENTER"
                           prefWidth="256.0"
                           maxWidth="1.7976931348623157E308"
                           prefHeight="150.0"
                           minHeight="150.0"
                           maxHeight="150.0"
                           styleClass="game-thumb-wrap customer-avatar-wrap">
                    <children>
                        <ImageView fx:id="gameImage"
                                   fitWidth="256.0"
                                   fitHeight="150.0"
                                   pickOnBounds="true"
                                   preserveRatio="false"
                                   smooth="true"
                                   managed="true" />

                        <Label fx:id="imagePlaceholder"
                               styleClass="img-placeholder"
                               text="GAME"
                               mouseTransparent="true" />

                        <HBox alignment="TOP_RIGHT"
                              pickOnBounds="false"
                              mouseTransparent="true"
                              prefWidth="256.0"
                              prefHeight="150.0"
                              StackPane.alignment="TOP_RIGHT" />
                    </children>
                </StackPane>

                <VBox alignment="TOP_LEFT"
                      fillWidth="true"
                      spacing="6.0">
                    <children>
                        <Label fx:id="titleLabel"
                               maxWidth="1.7976931348623157E308"
                               styleClass="game-title"
                               text="Game"
                               wrapText="true" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT"
                      fillHeight="true"
                      spacing="10.0">
                    <children>
                        <VBox spacing="4.0"
                              styleClass="customer-mini-stat"
                              HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets top="8.0" right="10.0" bottom="8.0" left="10.0" />
                            </padding>
                            <children>
                                <Label styleClass="game-key" text="Game ID" />
                                <Label fx:id="infoValueLabel"
                                       styleClass="game-value"
                                       text="0000"
                                       wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT"
                      spacing="10.0"
                      maxWidth="1.7976931348623157E308">
                    <children>
                        <Button fx:id="editBtn"
                                onAction="#edit"
                                prefHeight="38.0"
                                prefWidth="86.0"
                                text="Edit">
                            <styleClass>
                                <String fx:value="btn-blue" />
                                <String fx:value="game-action-btn" />
                            </styleClass>
                        </Button>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="removeBtn"
                                onAction="#remove"
                                prefHeight="38.0"
                                prefWidth="96.0"
                                text="Remove">
                            <styleClass>
                                <String fx:value="btn-pink" />
                                <String fx:value="game-action-btn" />
                            </styleClass>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>