<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane alignment="CENTER" prefHeight="760.0" prefWidth="980.0" stylesheets="@../css/pixel_admin_reactive.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admin_controllers.PcDrawerController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
    <styleClass>
        <String fx:value="drawer-overlay" />
        <String fx:value="pc-page-modal-overlay" />
    </styleClass>

    <VBox fx:id="rootDrawer" maxHeight="-Infinity" maxWidth="620.0" minHeight="-Infinity" minWidth="580.0" prefWidth="620.0" spacing="14.0" StackPane.alignment="CENTER">
        <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label styleClass="detail-drawer-title pcs-drawer-main-title" text="Selected PC" />
            <Region HBox.hgrow="ALWAYS" />
          <Button onAction="#close" styleClass="popup-close-btn" text="✕" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label styleClass="panel-title pcs-session-title" text="LIVE SESSION CONTROL" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblSelectedStatus" style="-fx-font-size: 9px;" styleClass="pcs-status-badge" text="ONLINE" />
        </HBox>

        <StackPane maxWidth="1.7976931348623157E308" styleClass="pcs-focus-visual pcs-session-hero detail-drawer-hero">
            <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="5.0" styleClass="pcs-focus-screen">
                <Label fx:id="lblSelectedPc" style="-fx-font-size: 16px;" styleClass="pcs-focus-name" text="PC-07" />
                <Label fx:id="lblSelectedUser" alignment="CENTER" style="-fx-font-size: 10px;" styleClass="pcs-focus-user" text="No User" wrapText="true" />
            </VBox>
        </StackPane>

        <HBox spacing="8.0" styleClass="pcs-session-chip-row">
            <VBox spacing="4.0" styleClass="pcs-session-chip" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="10.0" left="12.0" right="12.0" top="10.0" /></padding>
                <Label style="-fx-font-size: 9px;" styleClass="mini-key" text="Session Time" />
                <Label fx:id="lblSelectedSession" style="-fx-font-size: 10px;" styleClass="mini-warn" text="01:42:18" />
            </VBox>
            <VBox spacing="4.0" styleClass="pcs-session-chip" HBox.hgrow="ALWAYS">
                <padding>
                <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
             </padding>
                <Label style="-fx-font-size: 9px;" styleClass="mini-key" text="State" />
                <Label fx:id="lblSessionCurrentState" style="-fx-font-size: 10px;" styleClass="mini-warn" text="Running" />
            </VBox>
        </HBox>

        <VBox spacing="8.0" styleClass="pcs-session-summary detail-drawer-section">
            <HBox>
                <padding><Insets bottom="10.0" left="12.0" right="12.0" top="10.0" /></padding>
                <Label style="-fx-font-size: 9px;" styleClass="mini-key" text="User" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblSessionCurrentUser" style="-fx-font-size: 10px;" styleClass="mini-ok" text="Available" />
             <styleClass>
                <String fx:value="mini-row" />
                <String fx:value="pcs-side-row" />
             </styleClass>
            </HBox>
        </VBox>

        <HBox spacing="10.0" styleClass="pcs-action-row">
            <Button fx:id="btnUnlock" maxWidth="1.7976931348623157E308" onAction="#handleUnlock" style="-fx-font-size: 9px;" text="Unlock" HBox.hgrow="ALWAYS">
                <styleClass><String fx:value="btn-white" /><String fx:value="pcs-session-btn" /></styleClass>
            </Button>
            <Button fx:id="btnLock" maxWidth="1.7976931348623157E308" onAction="#handleLock" style="-fx-font-size: 9px;" text="Lock" HBox.hgrow="ALWAYS">
                <styleClass><String fx:value="btn-pink" /><String fx:value="pcs-session-btn" /></styleClass>
            </Button>
        </HBox>
        <Button fx:id="btnShutDown" maxWidth="1.7976931348623157E308" onAction="#handleShutDown" style="-fx-font-size: 9px;" text="Shut Down" textFill="WHITE">
            <styleClass><String fx:value="btn-danger" /><String fx:value="pcs-session-btn" /><String fx:value="pcs-session-btn-danger" /></styleClass>
        </Button>
       <styleClass>
          <String fx:value="pcs-modal-card" />
          <String fx:value="pc-neon-modal" />
          <String fx:value="pc-selected-modal" />
          <String fx:value="modal-surface-clean" />
       </styleClass>
    </VBox>
</StackPane>
