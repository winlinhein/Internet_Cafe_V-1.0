<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane alignment="CENTER_RIGHT" prefHeight="720.0" prefWidth="980.0" stylesheets="@../CSS/pixel_admin_reactive.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admin_controllers.AddCustomerController">
    <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0" /></padding>
    <styleClass>
        <String fx:value="drawer-overlay" />
        <String fx:value="customer-modal-overlay" />
        <String fx:value="customer-page-modal-overlay" />
    </styleClass>

    <VBox fx:id="rootModal" maxHeight="-Infinity" maxWidth="505.0" prefHeight="645.0" prefWidth="505.0" spacing="14.0" StackPane.alignment="CENTER_RIGHT">
        <padding><Insets bottom="18.0" left="18.0" right="18.0" top="18.0" /></padding>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label fx:id="titleLabel" styleClass="edit-popup-title" text="Add Member" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#close" styleClass="popup-close-btn" text="✕" />
        </HBox>
        <VBox prefHeight="485.0" prefWidth="391.0" spacing="8.0">
            <Label styleClass="popup-field-label" text="Member Name" />
            <TextField fx:id="nameField" styleClass="popup-field" />
            <Label styleClass="popup-field-label" text="Member Type" />
            <ComboBox fx:id="memberTypeCombo" promptText="Select member type">
             <styleClass>
                <String fx:value="game-category-box" />
                <String fx:value="popup-combo-box" />
             </styleClass></ComboBox>
          <Label styleClass="popup-field-label" text="Phone" />
          <TextField fx:id="phoneField" styleClass="popup-field" />
          <Label styleClass="popup-field-label" text="Email" />
          <TextField fx:id="emailField" styleClass="popup-field" />
          <Label styleClass="popup-field-label" text="Password" />
          <PasswordField fx:id="passwordField" prefHeight="33.0" prefWidth="391.0" styleClass="popup-field" />
          <Label styleClass="popup-field-label" text="Confirm Password" />
          <PasswordField fx:id="confirmPassword" prefHeight="34.0" prefWidth="391.0" styleClass="popup-field" />
            <Label styleClass="popup-field-label" text="Point Balance" />
            <Label fx:id="pointsLabel" text="0 pts">
             <styleClass>
                <String fx:value="popup-static-value" />
                <String fx:value="customer-points-value" />
             </styleClass></Label>
        </VBox>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Button onAction="#save" styleClass="btn-blue" text="Add Member" />
            <Button disable="true" onAction="#cancel" styleClass="btn-white" text="Cancel" visible="false" />
        </HBox>
       <styleClass>
          <String fx:value="edit-popup" />
          <String fx:value="customer-modal" />
          <String fx:value="nova-modal-card" />
          <String fx:value="modal-surface-clean" />
          <String fx:value="customer-neon-modal" />
       </styleClass>
    </VBox>
</StackPane>
