<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane alignment="CENTER_RIGHT" prefHeight="560.0" prefWidth="900.0" stylesheets="@../CSS/pixel_admin_reactive.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admin_controllers.AddNewPointController">
    <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0" /></padding>
    <styleClass>
        <String fx:value="drawer-overlay" />
        <String fx:value="customer-modal-overlay" />
        <String fx:value="customer-page-modal-overlay" />
    </styleClass>

    <VBox fx:id="rootModal" maxHeight="-Infinity" maxWidth="390.0" prefWidth="390.0" spacing="14.0" StackPane.alignment="CENTER_RIGHT">
        <padding><Insets bottom="18.0" left="18.0" right="18.0" top="18.0" /></padding>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label fx:id="titleLabel" styleClass="edit-popup-title" text="Add Points" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#close" styleClass="popup-close-btn" text="✕" />
        </HBox>
        <VBox spacing="8.0">
            <TextField fx:id="amountField" promptText="500" styleClass="popup-field" />
        </VBox>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Button onAction="#save" styleClass="btn-blue" text="Confirm Top Up" />
            <Button disable="true" onAction="#close" styleClass="btn-white" text="Cancel" visible="false" />
        </HBox>
       <styleClass>
          <String fx:value="edit-popup" />
          <String fx:value="customer-modal" />
          <String fx:value="nova-modal-card" />
          <String fx:value="modal-surface-clean" />
          <String fx:value="customer-neon-modal" />
       </styleClass>
    </VBox>
</StackPane>
