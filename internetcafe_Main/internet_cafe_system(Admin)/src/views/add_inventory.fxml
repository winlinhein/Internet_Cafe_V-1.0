<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="editPopup" maxWidth="460.0" prefWidth="460.0" spacing="14.0" styleClass="edit-popup" stylesheets="@../CSS/pixel_admin_reactive.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admin_controllers.AddInventoryController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label styleClass="edit-popup-title" text="Add Product" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#closeEditPopup" styleClass="popup-close-btn" text="✕" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="14.0">
        <StackPane minHeight="118.0" prefHeight="118.0" prefWidth="118.0" styleClass="edit-image-preview-wrap">
            <ImageView fx:id="editImagePreview" fitHeight="82.0" fitWidth="82.0" pickOnBounds="true" preserveRatio="true" />
            <Label fx:id="editImagePlaceholder" styleClass="img-placeholder" text="IMG" />
        </StackPane>
        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <Label styleClass="popup-field-label" text="Image Path" />
            <TextField fx:id="editImagePathField" promptText="Choose an image..." styleClass="popup-field" />
            <HBox spacing="10.0">
                <Button onAction="#chooseImage" styleClass="chip-btn" text="Browse" />
                <Button onAction="#resetImage" styleClass="chip-btn" text="Reset" />
            </HBox>
        </VBox>
    </HBox>

    <VBox spacing="8.0">
        <Label styleClass="popup-field-label" text="Product Name" />
        <TextField fx:id="editNameField" styleClass="popup-field" />
    </VBox>

    <VBox spacing="8.0">
        <Label styleClass="popup-field-label" text="Category" />
        <ComboBox fx:id="comboType" prefHeight="39.0" prefWidth="417.0">
         <styleClass>
            <String fx:value="game-category-box" />
            <String fx:value="combo-box-popup" />
         </styleClass></ComboBox>
    </VBox>

    <HBox spacing="12.0">
        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <Label styleClass="popup-field-label" text="Price" />
            <TextField fx:id="editPriceField" styleClass="popup-field" />
        </VBox>
        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <Label styleClass="popup-field-label" text="Stock" />
            <TextField fx:id="editStockField" styleClass="popup-field" />
        </VBox>
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#saveEditedProduct" prefHeight="40.0" prefWidth="93.0" styleClass="btn-pink" text="Add" />
    </HBox>
</VBox>
