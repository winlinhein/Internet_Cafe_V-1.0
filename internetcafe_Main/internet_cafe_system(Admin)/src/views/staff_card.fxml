<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootCard" minHeight="240.0" minWidth="248.0" prefHeight="240.0" prefWidth="248.0" spacing="14.0" stylesheets="@../CSS/pixel_admin_reactive.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admin_controllers.StaffCardController">
    <padding>
        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
    </padding>

    <StackPane maxWidth="Infinity" prefHeight="82.0" styleClass="staff-card-top-simple">
        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <StackPane styleClass="staff-avatar-simple">
                <Label fx:id="lblInitials" styleClass="staff-avatar-text" text="NA" />
            </StackPane>

            <VBox alignment="CENTER_LEFT" spacing="6.0">
                <Label fx:id="lblName" text="Staff Name">
               <styleClass>
                  <String fx:value="product-title" />
                  <String fx:value="staff-name-simple" />
               </styleClass></Label>
                <Label fx:id="lblRole" styleClass="staff-role-text-simple" text="Staff Admin" />
            </VBox>
        </HBox>
    </StackPane>

    <VBox alignment="CENTER_LEFT" spacing="10.0" styleClass="staff-info-panel-simple">
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label styleClass="staff-info-key-simple" text="Email" />
            <Label fx:id="lblEmail" styleClass="staff-info-value" text="admin@icafe.local" wrapText="true" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label styleClass="staff-info-key-simple" text="Phone" />
            <Label fx:id="lblPhone" styleClass="staff-info-value" text="+95 9 000 000000" />
        </HBox>

        <Label fx:id="lblStatus" disable="true" styleClass="staff-status-text-simple" text="Ready for Shift" visible="false" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button alignment="CENTER" focusTraversable="false" mnemonicParsing="false" onAction="#handleManageAction" styleClass="staff-open-btn-simple" text="View Profile" />
    </HBox>
   <styleClass>
      <String fx:value="staff-card-simple" />
   </styleClass>
</VBox>
