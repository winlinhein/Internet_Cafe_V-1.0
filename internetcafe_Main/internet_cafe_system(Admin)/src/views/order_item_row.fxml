<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="itemRoot" alignment="CENTER_LEFT" prefWidth="340.0" spacing="10.0" styleClass="notify-item-card" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admin_controllers.OrderItemRow">
    <padding>
        <Insets bottom="11.0" left="11.0" right="11.0" top="11.0" />
    </padding>

    <Region fx:id="dot">
        <styleClass>
            <String fx:value="notify-item-dot" />
            <String fx:value="notify-item-dot-info" />
        </styleClass>
    </Region>

    <VBox fx:id="textBox" spacing="5.0" HBox.hgrow="ALWAYS">
        <Label fx:id="titleLabel" styleClass="notify-item-title" text="Notification message" wrapText="true" />
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label fx:id="timeLabel" styleClass="notify-item-time" text="JUST NOW" />
            <Label fx:id="tagLabel" text="LIVE">
                <styleClass>
                    <String fx:value="notify-item-tag" />
                    <String fx:value="notify-item-tag-info" />
                </styleClass>
            </Label>
        </HBox>
    </VBox>

    <Button fx:id="dismissBtn" onAction="#dismiss" styleClass="notify-close-mini" text="✕" />
</HBox>