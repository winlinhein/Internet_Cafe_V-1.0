<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="overlay" alignment="CENTER_RIGHT" pickOnBounds="true" prefHeight="640.0" prefWidth="920.0" stylesheets="@../CSS/pixel_admin_reactive.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admin_controllers.AddPcModalController">
    <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0" /></padding>
    <VBox fx:id="modalCard" maxHeight="-Infinity" maxWidth="468.0" prefHeight="299.0" prefWidth="468.0" spacing="10.0" StackPane.alignment="CENTER_RIGHT">
        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <VBox spacing="3.0">
                <Label fx:id="lblTitle" styleClass="edit-popup-title cyber-title" text="Add PC Station" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnClose" onAction="#handleCloseAction" styleClass="popup-close-btn" text="✕" />
        </HBox>

        <StackPane minHeight="76.0" prefHeight="76.0" styleClass="pcs-monitor cyber-popup-hero">
            <VBox alignment="CENTER" spacing="4.0" styleClass="pcs-monitor-inner">
                <Label fx:id="lblStation" styleClass="pcs-zone-label" text="NEW STATION" />
            </VBox>
        </StackPane>

        <VBox spacing="8.0">
            <Label styleClass="popup-field-label" text="PC Name" />
            <TextField fx:id="tfPcName" promptText="New PC">
                <styleClass>
                    <String fx:value="popup-field" />
                    <String fx:value="pcs-input-clean" />
                </styleClass>
            </TextField>
        </VBox>

        <HBox alignment="CENTER" prefHeight="44.0" prefWidth="274.0" spacing="10.0">
         <HBox prefHeight="100.0" prefWidth="200.0">
            <children>
                  <Button fx:id="btnAdd" maxWidth="1.7976931348623157E308" onAction="#handleAddAction" prefHeight="44.0" prefWidth="139.0" text="Add To Grid" HBox.hgrow="ALWAYS">
                      <styleClass>
                          <String fx:value="btn-blue" />
                          <String fx:value="cyber-action-btn" />
                      </styleClass>
                  </Button>
            </children>
         </HBox>
        </HBox>
      <styleClass>
         <String fx:value="edit-popup" />
         <String fx:value="cyber-modal-card" />
         <String fx:value="modal-surface-clean" />
         <String fx:value="pc-neon-modal" />
      </styleClass>
    </VBox>
   <styleClass>
      <String fx:value="edit-overlay" />
      <String fx:value="cyber-popup-overlay" />
      <String fx:value="pc-page-modal-overlay" />
   </styleClass>
</StackPane>
